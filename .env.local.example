# ─── ArtRevive Environment Variables ──────────────────────────────────────

# Vercel Blob Storage (required for upload + generated asset storage)
# Get from: Vercel Dashboard → Storage → Blob
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here

# Google Gemini / Imagen (required for Restyle mode)
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=your_google_gemini_api_key_here
# Or: GEMINI_API_KEY=your_google_gemini_api_key_here

# Anthropic Claude API (optional — legacy routes)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Restyle provider override (optional, defaults to 'google-imagen')
# Set to 'mock' to run without AI (returns source image as output)
# RESTYLE_PROVIDER=mock

# ─── Legacy Supabase (backward compat) ───────────────────────────────────
